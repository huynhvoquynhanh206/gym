# Leave DATABASE_URL unset to use local SQLite during development.
# For Supabase, copy the Session pooler connection string from Connect.
DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
DATABASE_POOL_SIZE=5
APP_TIME_ZONE=Asia/Ho_Chi_Minh
